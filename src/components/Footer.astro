---
import Link from "./Link.astro"

const isFrench = Astro.url.pathname.startsWith("/fr")

const en = {
	"Made in France with ❤️": "Made in France with ❤️",
	"Privacy policy": "Privacy policy",
	"source code": "source code",
	"Contact us": "Contact us",
	FAQ: "FAQ",
	by: "by",
	"Email support": "Email support",
	"GitHub issues": "GitHub issues",
	Documentation: "Documentation",
	"Beautiful customizable backgrounds": "Beautiful customizable backgrounds",
	"Quick access to your favorite sites": "Quick access to your favorite sites",
	"Built-in notes with markdown": "Built-in notes with markdown",
	"Minimal search experience": "Minimal search experience",
	"Pomodoro timer for productivity": "Pomodoro timer for productivity",
	"Weather & daily quotes": "Weather & daily quotes",
}

const fr = {
	"Made in France with ❤️": "Fabriqué en France avec ❤️",
	"Privacy policy": "Politique de confidentialité",
	"source code": "code source",
	"Contact us": "Nous contacter",
	FAQ: "FAQ",
	by: "par",
	"Email support": "Support par email",
	"GitHub issues": "Tickets GitHub",
	Documentation: "Documentation",

	"Beautiful customizable backgrounds": "Arrière-plans personnalisables",
	"Quick access to your favorite sites": "Accès rapide à vos sites favoris",
	"Built-in notes with markdown": "Notes avec Markdown",
	"Minimal search experience": "Barre de recherche minimaliste",
	"Pomodoro timer for productivity": "Minuteur Pomodoro",
	"Weather & daily quotes": "Météo et citations quotidiennes",
}

const trans = isFrench ? fr : en

const currentYear = new Date().getFullYear()
---

<script>
	window.onpageshow = () => {
		const signatures = document.getElementById("signature_span") as HTMLSpanElement
		const rowdir = Math.random() > 0.5 ? "row-reverse" : "row"
		signatures.style.setProperty("--dir", rowdir)
	}
</script>

<footer>
	<div class="container">
		<div class="branding">
			<Link href="/" title="Homepage" class="logo" aria-label="Homepage">
				<img src="/apple-touch-icon.png" alt="bonjourr logo" />
				<h2>Bonjourr</h2></Link
			>

			<p>
				Bonjourr is a minimalist and open source browser startpage inspired by iOS. Private,
				lightweight, customizable, and designed for a calmer browsing experience.
			</p>

			<p>
				© 2019 - {currentYear} ·
				<a href="https://github.com/victrme/Bonjourr">Source code</a>
			</p>
		</div>

		<div>
			<h3>Features</h3>
			<ul>
				<li>
					<Link href="/docs/overview#backgrounds"
						>{trans["Beautiful customizable backgrounds"]}</Link
					>
				</li>
				<li>
					<Link href="/docs/overview#quick-links"
						>{trans["Quick access to your favorite sites"]}</Link
					>
				</li>
				<li>
					<Link href="/docs/overview#notes">{trans["Built-in notes with markdown"]}</Link>
				</li>
				<li>
					<Link href="/docs/overview#searchbar">{trans["Minimal search experience"]}</Link
					>
				</li>
				<li>
					<Link href="/docs/overview#pomodoro"
						>{trans["Pomodoro timer for productivity"]}</Link
					>
				</li>
				<li>
					<Link href="/docs/overview#weather">{trans["Weather & daily quotes"]}</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>Help</h3>
			<ul>
				<li>
					<a href="mailto:bonjourr.app@protonmail.com">{trans["Email support"]}</a>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr/issues">{trans["GitHub issues"]}</a
					>
				</li>
				<li>
					<Link href="/docs">{trans["Documentation"]}</Link>
				</li>
				<li>
					<Link href="/docs/faq">{trans["FAQ"]}</Link>
				</li>
				<li>
					<Link href="/privacy">{trans["Privacy policy"]}</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>Social</h3>
			<ul>
				<li>
					<a href="https://bsky.app/profile/bonjourr.fr" rel="me">Bluesky</a>
				</li>
				<li>
					<a href="https://t.me/BonjourrStartpage" rel="me">Telegram</a>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr" rel="me">GitHub</a>
				</li>
			</ul>
		</div>
	</div>

	<div class="bottom">
		<hr />
		<div id="signature">
			<p>{trans["Made in France with ❤️"]}</p>

			<p>
				<span>{trans.by}</span>

				<span id="signature_span">
					<a href="https://victr.me" title="Victor's portfolio">Victor Azevedo</a>
					&
					<a href="https://tahoe.be" title="Tahoe's portfolio">Tahoe Beetschen</a>
				</span>
			</p>
		</div>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		font-size: 15px;
		color: var(--color-text-secondary);
		background-color: var(--color-background);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.container {
		display: grid;
		gap: 2rem;
		grid-template-columns: minmax(280px, 2.25fr) repeat(3, minmax(100px, 1fr));
		max-width: 1200px;
		margin-inline: auto;
		padding: 3em 2em;
	}

	.branding {
		max-width: none;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
		border-radius: 0.5rem;
	}

	.branding h2 {
		margin: 0;
		font-size: 1.65rem;
		color: var(--color-text);
	}

	.branding p {
		margin: 0.85rem 0 0;
		line-height: 1.75;
		max-width: 42rem;
	}

	footer h3 {
		margin: 0 0 1rem;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	footer ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.65rem;
	}

	footer li {
		margin: 0;
	}

	footer a {
		color: inherit;
		text-decoration: none;
	}

	footer a:hover,
	footer a:focus-visible {
		text-decoration: underline;
		color: var(--color-text);
	}

	.bottom {
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
	}

	.bottom hr {
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		margin: 0 0 1.5rem;

		@media (prefers-color-scheme: light) {
			border-top: 1px solid rgba(87, 87, 87, 0.2);
		}
	}

	#signature {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	#signature p {
		margin: 0;
		font-size: 0.8rem;
	}

	#signature_span {
		display: inline-flex;
		flex-direction: var(--dir);
		column-gap: 0.5rem;
		row-gap: 0.25rem;
		flex-wrap: wrap;
	}

	@media only screen and (max-width: 900px) {
		.container {
			grid-template-columns: repeat(2, minmax(220px, 1fr));
		}
	}

	@media only screen and (max-width: 680px) {
		.container {
			grid-template-columns: 1fr;
			padding-inline: 1.5rem;
		}

		#signature {
			justify-content: flex-start;
		}
	}
</style>
