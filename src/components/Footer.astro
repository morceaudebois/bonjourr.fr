---
import Link from "./Link.astro"

const isFrench = Astro.url.pathname.startsWith("/fr")

const en = {
	"Made in France with ❤️": "Made in France with ❤️",
	"Privacy policy": "Privacy policy",
	"source code": "source code",
	"Contact us": "Contact us",
	by: "by",
}
const fr = {
	"Made in France with ❤️": "Fabriqué en France avec ❤️",
	"Privacy policy": "Politique de confidentialité",
	"source code": "code source",
	"Contact us": "Contactez-nous",
	by: "par",
}
const trans = isFrench ? fr : en

const currentYear = new Date().getFullYear()
---

<script>
	window.onpageshow = () => {
		const signatures = document.getElementById("signature_span") as HTMLSpanElement
		const rowdir = Math.random() > 0.5 ? "row-reverse" : "row"
		signatures.style.setProperty("--dir", rowdir)
	}
</script>

<footer>
	<div class="container">
		<div class="branding">
			<div class="logo">
				<img src="/apple-touch-icon.png" alt="bonjourr logo" />
				<h2>Bonjourr</h2>
			</div>
			<p>
				Bonjourr is a minimalist and open source browser startpage inspired by iOS. Private,
				lightweight, customizable, and designed for a calmer browsing experience.
			</p>

			<p>
				© 2019 - {currentYear} ·
				<Link href="https://github.com/victrme/Bonjourr">Source code</Link>
			</p>
		</div>

		<div>
			<h3>Features</h3>
			<ul>
				<li><a href="">Beautiful customizable backgrounds</a></li>
				<li><a href="">Quick access to your favorite sites</a></li>
				<li><a href="">Built-in notes with markdown</a></li>
				<li><a href="">Minimal search experience</a></li>
				<li><a href="">Pomodoro timer for productivity</a></li>
				<li><a href="">Weather & daily quotes</a></li>
			</ul>
		</div>

		<div>
			<h3>Help</h3>
			<ul>
				<li><a href="">Email support</a></li>
				<li><a href="">GitHub issues</a></li>
				<li><a href="">Documentation</a></li>
				<li><a href="">FAQ</a></li>
				<li><Link href="/privacy">{trans["Privacy policy"]}</Link></li>
			</ul>
		</div>

		<div>
			<h3>Social</h3>
			<ul>
				<li><a href="">Bluesky</a></li>
				<li><a href="">Telegram</a></li>
				<li><a href="">GitHub</a></li>
			</ul>
		</div>

		<!-- <div id="legal">
			<p>
