---
import Link from "./Link.astro"
import { Icon } from "astro-icon/components"

const isFrench = Astro.url.pathname.startsWith("/fr")

const en = {
	trusted: "Trusted by 300k+ users worldwide",
	crafted: "Crafted in France with ❤️",
	"Privacy policy": "Privacy policy",
	"Source code": "Source code",
	"Contact us": "Contact us",
	FAQ: "FAQ",
	by: "by",
	"Email support": "Email support",
	"GitHub issues": "GitHub issues",
	Documentation: "Documentation",
	"Beautiful customizable backgrounds": "Beautiful customizable backgrounds",
	"Quick access to your favorite sites": "Quick access to your favorite sites",
	"Notes with markdown": "Notes with markdown",
	"Search bar": "Search bar",
	"Pomodoro timer": "Pomodoro timer",
	"Weather & quotes": "Weather & quotes",
	Features: "Features",
	Resources: "Resources",
	Community: "Community",
	desc: "Bonjourr is a minimalist and open source browser startpage inspired by iOS. Private, lightweight and customizable, it is designed for a calmer browsing experience.",
	"Install on:": "Install on:",
}

const fr = {
	trusted: "Adopté par plus de 300 000 utilisateurs dans le monde",
	crafted: "Fabriqué en France avec ❤️",
	"Privacy policy": "Politique de confidentialité",
	"Source code": "Code source",
	"Contact us": "Nous contacter",
	FAQ: "FAQ",
	by: "par",
	"Email support": "Support par email",
	"GitHub issues": "Tickets GitHub",
	Documentation: "Documentation",

	"Beautiful customizable backgrounds": "Arrière-plans personnalisables",
	"Quick access to your favorite sites": "Accès rapide à vos sites favoris",
	"Notes with markdown": "Notes avec Markdown",
	"Search bar": "Barre de recherche",
	"Pomodoro timer": "Minuteur pomodoro",
	"Weather & quotes": "Météo quotidienne",
	Features: "Fonctionnalités",
	Resources: "Ressources",
	Community: "Communauté",
	desc: "Bonjourr est une page d’accueil de navigateur minimaliste et open source inspirée d’iOS. Privée, légère et personnalisable, elle offre une expérience de navigation plus calme et plus agréable.",
	"Install on:": "Installer sur :",
}

const trans = isFrench ? fr : en

const currentYear = new Date().getFullYear()
---

<script>
	window.onpageshow = () => {
		const signatures = document.getElementById("signature_span") as HTMLSpanElement
		const rowdir = Math.random() > 0.5 ? "row-reverse" : "row"
		signatures.style.setProperty("--dir", rowdir)
	}
</script>

<footer>
	<div class="container">
		<div class="branding">
			<Link href="/" title="Homepage" class="logo" aria-label="Homepage">
				<img src="/apple-touch-icon.png" alt="bonjourr logo" />
				<h2>Bonjourr</h2></Link
			>

			<p>
				{trans["desc"]}
			</p>

			<div id="browser_links">
				<p>{trans["Install on:"]}</p>

				<ul>
					<li>
						<a
							href="https://addons.mozilla.org/firefox/addon/bonjourr-startpage/"
							title="Download for Firefox"
						>
							<img src="/browsers/firefox.svg" alt="" />
						</a>
					</li>
					<li>
						<a
							href="https://chrome.google.com/webstore/detail/bonjourr-%C2%B7-minimalist-lig/dlnejlppicbjfcfcedcflplfjajinajd"
							title="Download Bonjourr for Chrome"
						>
							<img src="/browsers/chrome.svg" alt="" />
						</a>
					</li>
					<li>
						<a href="/docs#safari" title="Install Bonjourr on Safari">
							<img src="/browsers/safari.svg" alt="" />
						</a>
					</li>
					<li>
						<a
							href="https://microsoftedge.microsoft.com/addons/detail/bonjourr/dehmmlejmefjphdeoagelkpaoolicmid"
							title="Download Bonjourr for Edge"
						>
							<img src="/browsers/edge.svg" alt="" />
						</a>
					</li>
				</ul>
			</div>

			<p>
				© 2019 - {currentYear} ·
				<a href="https://github.com/victrme/Bonjourr">
					<span>{trans["Source code"]}</span></a
				>
			</p>
		</div>

		<div>
			<h3>{trans["Features"]}</h3>
			<ul>
				<li>
					<Link href="/docs/overview#backgrounds">
						<Icon name="heroicons:photo" />
						<span>{trans["Beautiful customizable backgrounds"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/overview#quick-links">
						<Icon name="heroicons:link" />
						<span>{trans["Quick access to your favorite sites"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/overview#notes">
						<Icon name="heroicons:pencil" />
						<span>{trans["Notes with markdown"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/overview#searchbar">
						<Icon name="heroicons:magnifying-glass" />
						<span>{trans["Search bar"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/overview#pomodoro">
						<Icon name="heroicons:clock" />
						<span>{trans["Pomodoro timer"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/overview#weather">
						<Icon name="heroicons:sun" />
						<span>{trans["Weather & quotes"]}</span>
					</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>{trans["Resources"]}</h3>
			<ul>
				<li>
					<Link href="/docs">
						<Icon name="heroicons:book-open" />
						<span>{trans["Documentation"]}</span>
					</Link>
				</li>
				<li>
					<a href="mailto:bonjourr.app@protonmail.com">
						<Icon name="heroicons:envelope" />
						<span>{trans["Email support"]}</span>
					</a>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr/issues">
						<Icon name="heroicons:bug-ant" />
						<span>{trans["GitHub issues"]}</span>
					</a>
				</li>
				<li>
					<Link href="/docs/faq">
						<Icon name="heroicons:question-mark-circle" />
						<span>{trans["FAQ"]}</span>
					</Link>
				</li>
				<li>
					<Link href="/privacy">
						<Icon name="heroicons:shield-check" />
						<span>{trans["Privacy policy"]}</span>
					</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>{trans["Community"]}</h3>
			<ul>
				<li>
					<a href="https://ko-fi.com/bonjourr" rel="me">
						<Icon name="fa7-brands:ko-fi" />
						<span>Ko-fi</span>
					</a>
				</li>
				<li>
					<a href="https://discord.gg/CCAR9J4qVg" rel="me"
						><Icon name="fa7-brands:discord" />
						<span>Discord</span></a
					>
				</li>
				<li>
					<a href="https://bsky.app/profile/bonjourr.fr" rel="me">
						<Icon name="fa7-brands:bluesky" />
						<span>Bluesky</span></a
					>
				</li>
				<li>
					<a href="https://twitter.com/bonjourrteam" rel="me">
						<Icon name="fa7-brands:twitter" />
						<span>Twitter</span></a
					>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr" rel="me"
						><Icon name="fa7-brands:github" />
						<span>GitHub</span></a
					>
				</li>
			</ul>
		</div>
	</div>

	<div class="bottom">
		<hr />
		<div id="signature">
			<p id="trusted">~ {trans["trusted"]} ~</p>

			<p>{trans["crafted"]}</p>
			<p>
				<span>{trans.by}</span>

				<span id="signature_span">
					<a href="https://victr.me" title="Victor's portfolio"
						><span>Victor Azevedo</span></a
					>
					&
					<a href="https://tahoe.be" title="Tahoe's portfolio"
						><span>Tahoe Beetschen</span></a
					>
				</span>
			</p>
		</div>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		font-size: 15px;
		color: var(--color-text-secondary);
		background-color: var(--color-background);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	@media (prefers-color-scheme: light) {
		footer {
			border-top: 1px solid rgba(87, 87, 87, 0.2);
		}
	}

	.container {
		display: grid;
		gap: 2rem;
		grid-template-columns: minmax(280px, 2.25fr) repeat(3, minmax(100px, 1fr));
		max-width: 1200px;
		margin-inline: auto;
		padding: 3em 2em 0 2em;
	}

	.branding {
		max-width: none;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
		border-radius: 0.5rem;
	}

	.branding h2 {
		margin: 0;
		font-size: 1.65rem;
		color: var(--color-text);
	}

	.branding p {
		margin: 0.85rem 0 0;
		line-height: 1.75;
		max-width: 42rem;
	}

	footer h3 {
		margin: 0 0 1rem;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	footer ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.75rem;
	}

	footer li a {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	footer li :global(svg) {
		min-width: 2em;
		height: 1.5em;
		display: inline;
		vertical-align: bottom;
	}

	footer a {
		color: inherit;
		text-decoration: none;
	}

	footer a:hover span,
	footer a:focus-visible span {
		text-decoration: underline;
		color: var(--color-text);
	}

	#browser_links {
		margin-top: 1.5rem;
		display: flex;
	}

	#browser_links p {
		font-size: 0.95rem;
		font-weight: 600;
		margin-right: 0.4em;
	}

	#browser_links ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		align-items: flex-start;
	}

	#browser_links li {
		display: flex;
		align-items: center;
		gap: 0 !important;
	}

	#browser_links li a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		padding: 1.5rem;
		border-radius: 0.5rem;
		transition: all 200ms ease;
		background-color: rgba(0, 0, 0, 0);
	}

	#browser_links li a:hover,
	#browser_links li a:focus-visible {
		background-color: rgba(255, 255, 255, 0.12);
		transform: scale(1.1);
	}

	@media (prefers-color-scheme: light) {
		#browser_links li a:hover,
		#browser_links li a:focus-visible {
			background-color: rgba(0, 0, 0, 0.08);
		}
	}

	#browser_links img {
		width: 2rem;
		height: 2rem;
		display: block;
	}

	.bottom {
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
	}

	.bottom hr {
		width: 100%;
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		margin: 0 0 1.5rem;

		@media (prefers-color-scheme: light) {
			border-top: 1px solid rgba(87, 87, 87, 0.2);
		}
	}

	#signature {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	#signature #trusted {
		margin-bottom: 1em;
	}

	#signature p {
		margin: 0;
		font-size: 0.8rem;
	}

	#signature_span {
		display: inline-flex;
		flex-direction: var(--dir);
		column-gap: 0.25em;
		row-gap: 0.25rem;
		flex-wrap: wrap;
	}

	@media only screen and (max-width: 1024px) {
		.container {
			grid-template-columns: repeat(2, minmax(220px, 1fr));
		}
	}

	@media only screen and (max-width: 680px) {
		.container {
			grid-template-columns: 1fr;
			padding-inline: 1.5rem;
		}

		#signature {
			justify-content: flex-start;
		}
	}
</style>
