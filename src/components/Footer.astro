---
import Link from "./Link.astro"
import { Icon } from "astro-icon/components"
import { getLangFromUrl, useTranslations } from "../i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const currentYear = new Date().getFullYear()
---

<script>
	window.onpageshow = () => {
		const signatures = document.getElementById("signature_span") as HTMLSpanElement
		const rowdir = Math.random() > 0.5 ? "row-reverse" : "row"
		signatures.style.setProperty("--dir", rowdir)
	}
</script>

<footer>
	<div class="container">
		<div class="branding">
			<Link href="/" title="Homepage" class="logo" aria-label="Homepage">
				<img src="/apple-touch-icon.png" alt="bonjourr logo" />
				<h2>Bonjourr</h2></Link
			>

			<p>
				{t("desc")}
			</p>

			<div id="browser_links">
				<p>{t("Install on:")}</p>

				<ul>
					<li>
						<a
							href="https://addons.mozilla.org/firefox/addon/bonjourr-startpage/"
							title="Download for Firefox"
						>
							<img src="/browsers/firefox.svg" alt="" />
						</a>
					</li>
					<li>
						<a
							href="https://chrome.google.com/webstore/detail/bonjourr-%C2%B7-minimalist-lig/dlnejlppicbjfcfcedcflplfjajinajd"
							title="Download Bonjourr for Chrome"
						>
							<img src="/browsers/chrome.svg" alt="" />
						</a>
					</li>
					<li>
						<a href="/docs#-safari-macos" title="Install Bonjourr on Safari">
							<img src="/browsers/safari.svg" alt="" />
						</a>
					</li>
					<li>
						<a
							href="https://microsoftedge.microsoft.com/addons/detail/bonjourr/dehmmlejmefjphdeoagelkpaoolicmid"
							title="Download Bonjourr for Edge"
						>
							<img src="/browsers/edge.svg" alt="" />
						</a>
					</li>
				</ul>
			</div>

			<p>
				© 2019 - {currentYear} · <span>{t("Source codes")}:</span>
				<a href="https://github.com/victrme/Bonjourr">{t("extension")}</a>, <a
					href="https://github.com/victrme/Bonjourr">{t("website")}</a
				>
			</p>
		</div>

		<div>
			<h3>{t("Features")}</h3>
			<ul>
				<li>
					<Link href="/docs/customisation/backgrounds/">
						<Icon name="heroicons:photo" />
						<span>{t("Beautiful customizable backgrounds")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/widgets/quick-links/">
						<Icon name="heroicons:link" />
						<span>{t("Quick access to your favorite sites")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/widgets/notes/">
						<Icon name="heroicons:pencil" />
						<span>{t("Notes with Markdown")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/widgets/search-bar/">
						<Icon name="heroicons:magnifying-glass" />
						<span>{t("Search bar")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/widgets/pomodoro">
						<Icon name="heroicons:clock" />
						<span>{t("Pomodoro timer")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/widgets/weather">
						<Icon name="heroicons:sun" />
						<span>{t("Weather & quotes")}</span>
					</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>{t("Resources")}</h3>
			<ul>
				<li>
					<Link href="/docs">
						<Icon name="heroicons:book-open" />
						<span>{t("Documentation")}</span>
					</Link>
				</li>
				<li>
					<a href="mailto:bonjourr.app@protonmail.com">
						<Icon name="heroicons:envelope" />
						<span>{t("Email support")}</span>
					</a>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr/issues">
						<Icon name="heroicons:bug-ant" />
						<span>{t("GitHub issues")}</span>
					</a>
				</li>
				<li>
					<Link href="/docs/reference/faq/">
						<Icon name="heroicons:question-mark-circle" />
						<span>{t("FAQ")}</span>
					</Link>
				</li>
				<li>
					<Link href="/docs/reference/privacy-policy/">
						<Icon name="heroicons:shield-check" />
						<span>{t("Privacy policy")}</span>
					</Link>
				</li>
			</ul>
		</div>

		<div>
			<h3>{t("Community")}</h3>
			<ul>
				<li>
					<a href="https://ko-fi.com/bonjourr" rel="me">
						<Icon name="fa7-brands:ko-fi" />
						<span>Ko-fi</span>
					</a>
				</li>
				<li>
					<a href="https://discord.gg/CCAR9J4qVg" rel="me"
						><Icon name="fa7-brands:discord" />
						<span>Discord</span></a
					>
				</li>
				<li>
					<a href="https://bsky.app/profile/bonjourr.fr" rel="me">
						<Icon name="fa7-brands:bluesky" />
						<span>Bluesky</span></a
					>
				</li>
				<li>
					<a href="https://twitter.com/bonjourrteam" rel="me">
						<Icon name="fa7-brands:twitter" />
						<span>Twitter</span></a
					>
				</li>
				<li>
					<a href="https://github.com/victrme/Bonjourr" rel="me"
						><Icon name="fa7-brands:github" />
						<span>GitHub</span></a
					>
				</li>
			</ul>
		</div>
	</div>

	<div class="bottom">
		<hr />
		<div id="signature">
			<p id="trusted">~ {t("trusted")} ~</p>

			<p>{t("crafted")}</p>
			<p>
				<span>{t("by")}</span>

				<span id="signature_span">
					<a href="https://victr.me" title="Victor's portfolio"
						><span>Victor Azevedo</span></a
					>
					&
					<a href="https://tahoe.be" title="Tahoe's portfolio"
						><span>Tahoe Beetschen</span></a
					>
				</span>
			</p>
		</div>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		font-size: 15px;
		color: var(--color-text-secondary);
		background-color: var(--color-background);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	@media (prefers-color-scheme: light) {
		footer {
			border-top: 1px solid rgba(87, 87, 87, 0.2);
		}
	}

	.container {
		display: grid;
		gap: 2rem;
		grid-template-columns: minmax(280px, 2.25fr) repeat(3, minmax(100px, 1fr));
		max-width: 1200px;
		margin-inline: auto;
		padding: 3em 2em 0 2em;
	}

	.branding {
		max-width: none;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
		border-radius: 0.5rem;
	}

	.branding h2 {
		margin: 0;
		font-size: 1.65rem;
		color: var(--color-text);
		font-weight: 500;
	}

	.branding p {
		margin: 0.85rem 0 0;
		line-height: 1.75;
		max-width: 42rem;
	}

	footer h3 {
		margin: 0 0 1rem;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	footer ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.75rem;
	}

	footer li a {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	footer li :global(svg) {
		min-width: 2em;
		height: 1.5em;
		display: inline;
		vertical-align: bottom;
	}

	footer a {
		color: inherit;
		text-decoration: none;
	}

	.branding p a:hover,
	.branding p a:focus-visible,
	footer a:hover span,
	footer a:focus-visible span {
		text-decoration: underline;
		color: var(--color-text);
	}

	#browser_links {
		margin-top: 1.5rem;
		display: flex;
	}

	#browser_links p {
		font-size: 0.95rem;
		font-weight: 600;
		margin-right: 0.4em;
	}

	#browser_links ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		align-items: flex-start;
	}

	#browser_links li {
		display: flex;
		align-items: center;
		gap: 0 !important;
	}

	#browser_links li a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		padding: 1.5rem;
		border-radius: 0.5rem;
		transition: all 200ms ease;
		background-color: rgba(0, 0, 0, 0);
	}

	#browser_links li a:hover,
	#browser_links li a:focus-visible {
		background-color: rgba(255, 255, 255, 0.12);
		transform: scale(1.1);
	}

	@media (prefers-color-scheme: light) {
		#browser_links li a:hover,
		#browser_links li a:focus-visible {
			background-color: rgba(0, 0, 0, 0.08);
		}
	}

	#browser_links img {
		width: 2rem;
		height: 2rem;
		display: block;
	}

	.bottom {
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
	}

	.bottom hr {
		width: 100%;
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		margin: 0 0 1.5rem;

		@media (prefers-color-scheme: light) {
			border-top: 1px solid rgba(87, 87, 87, 0.2);
		}
	}

	#signature {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	#signature #trusted {
		margin-bottom: 1em;
	}

	#signature p {
		margin: 0;
		font-size: 0.8rem;
	}

	#signature_span {
		display: inline-flex;
		flex-direction: var(--dir);
		column-gap: 0.25em;
		row-gap: 0.25rem;
		flex-wrap: wrap;
	}

	@media only screen and (max-width: 1024px) {
		.container {
			grid-template-columns: repeat(2, minmax(220px, 1fr));
		}
	}

	@media only screen and (max-width: 680px) {
		.container {
			grid-template-columns: 1fr;
			padding-inline: 1.5rem;
		}

		#signature {
			justify-content: flex-start;
		}
	}
</style>
