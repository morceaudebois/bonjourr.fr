	</div>

	<div class="bottom">
		<hr />
		<div id="signature">
			<p>{trans["Made in France with ❤️"]}</p>

			<p>
				<span>{trans.by}</span>

				<span id="signature_span">
					<a href="https://victr.me" title="Victor's portfolio">Victor Azevedo</a>
					&
					<a href="https://tahoe.be" title="Tahoe's portfolio">Tahoe Beetschen</a>
				</span>
			</p>
		</div>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		font-size: 15px;
		color: var(--color-text-secondary);
		background-color: var(--color-background);
		padding: 3em 2em;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.container {
		display: grid;
		gap: 2rem;
		grid-template-columns: minmax(280px, 2.5fr) repeat(3, minmax(100px, 1fr));
		max-width: 1200px;
		margin-inline: auto;
		padding: 0 0.5rem;
	}

	.branding {
		max-width: none;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
		border-radius: 0.5rem;
	}

	.branding h2 {
		margin: 0;
		font-size: 1.65rem;
		color: var(--color-text);
	}

	.branding p {
		margin: 0.85rem 0 0;
		line-height: 1.75;
		max-width: 42rem;
	}

	footer h3 {
		margin: 0 0 1rem;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	footer ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.65rem;
	}

	footer li {
		margin: 0;
	}

	footer a {
		color: inherit;
		text-decoration: none;
	}

	footer a:hover,
	footer a:focus-visible {
		text-decoration: underline;
		color: var(--color-text);
	}

	.bottom {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
	}

	.bottom hr {
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		margin: 0 0 1.5rem;
	}

	#signature {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	#signature p {
		margin: 0;
		font-size: 0.85rem;
	}

	#signature_span {
		display: inline-flex;
		flex-direction: var(--dir);
		column-gap: 0.5rem;
		row-gap: 0.25rem;
		flex-wrap: wrap;
	}

	@media only screen and (max-width: 900px) {
		.container {
			grid-template-columns: repeat(2, minmax(220px, 1fr));
			padding: 0 1rem;
		}
	}

	@media only screen and (max-width: 680px) {
		.container {
			grid-template-columns: 1fr;
		}

		footer {
			padding: 2rem 1rem 1rem;
		}

		#signature {
			justify-content: flex-start;
		}
	}
</style>
