---
import { getCollection } from "astro:content"

const posts = await getCollection("blog")
const latestPosts = posts
	.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
	.slice(0, 3)
---

<div id="blog">
	<div class="section-wrapper">
		<h2>Latest updates</h2>
		<p>Read the latest Bonjourr news, development updates, and release announcements.</p>

		<div class="blog-grid">
			{
				latestPosts.map((post) => (
					<a class="blog-card" href={`/blog/${post.slug}`}>
						<div>
							<p class="blog-date">
								{new Date(post.data.pubDate).toLocaleDateString("en-US", {
									year: "numeric",
									month: "short",
									day: "numeric",
								})}
							</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</div>
						<span class="read-more">Read more →</span>
					</a>
				))
			}
		</div>

		<div class="blog-action">
			<a class="button" href="/blog">See all updates</a>
		</div>
	</div>
</div>

<style>
	#blog {
		background: linear-gradient(180deg, rgba(17, 17, 17, 0.95) 0%, rgba(14, 14, 14, 0.95) 100%);
		color: white;
	}

	.blog-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		margin-top: 2rem;
	}

	.blog-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.75rem;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.12);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease;
	}

	.blog-card:hover {
		transform: translateY(-4px);
		border-color: rgba(255, 255, 255, 0.22);
		background: rgba(255, 255, 255, 0.08);
	}

	.blog-date {
		font-size: 0.95rem;
		opacity: 0.7;
		margin-bottom: 0.75rem;
	}

	.blog-card h3 {
		margin: 0 0 0.75rem;
		font-size: 1.35rem;
		line-height: 1.2;
	}

	.blog-card p {
		margin: 0;
		line-height: 1.8;
	}

	.read-more {
		margin-top: 1.5rem;
		font-weight: 600;
		opacity: 0.85;
	}

	.blog-action {
		margin-top: 2rem;
		text-align: center;
	}

	@media (max-width: 900px) {
		#blog .section-wrapper {
			padding: 64px 1.5rem;
		}
	}
</style>
