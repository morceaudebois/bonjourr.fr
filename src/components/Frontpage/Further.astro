---
import Link from "../Link.astro"
---

<h2>
	<slot name="title" />
</h2>

<div class="bloc">
	<h3>
		<slot name="contact-title" />
	</h3>

	<p>
		<slot name="contact-desc" />
	</p>

	<div class="btn-wrapper">
		<a href="https://bsky.app/profile/bonjourr.fr" class="button btn-themed">
			<img width="64" src="/frontpage/bluesky-blue.svg" class="icon" alt="" />
			<slot name="contact-button-bluesky" />
		</a>

		<a href="https://t.me/BonjourrStartpage" class="button btn-themed">
			<img width="64" src="/frontpage/telegram.svg" class="icon" alt="" />
			<slot name="contact-button-telegram" />
		</a>
	</div>
</div>

<div class="bloc">
	<h3>
		<slot name="docs-title" />
	</h3>

	<p>
		<slot name="docs-desc" />
	</p>

	<div class="btn-wrapper">
		<Link href="/docs" class="button btn-themed">
			<img width="64" src="/frontpage/docs.svg" class="icon" alt="" />
			<slot name="docs-button" />
		</Link>
	</div>
</div>

