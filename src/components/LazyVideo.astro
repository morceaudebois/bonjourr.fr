---
interface Props {
	src: string
	poster?: string
	loop?: boolean
	muted?: boolean
	controls?: boolean
	class?: string
	autoplay?: boolean
	playsinline?: boolean
}

const {
	src,
	poster,
	loop = true,
	muted = true,
	controls = true,
	class: className,
	autoplay = true,
	playsinline = true,
} = Astro.props
---

<video
	class={["lazy-video", className].filter(Boolean).join(" ")}
	data-src={src}
	poster={poster}
	loop={loop}
	muted={muted}
	controls={controls}
	playsinline={playsinline}
	{...autoplay ? { autoplay: true } : {}}></video>

<script>
	import LazyLoad from "vanilla-lazyload"

	new LazyLoad({
		elements_selector: ".lazy-video",
	})
</script>
