---
import Layout from "@layouts/Layout.astro"
import DocsTitle from "@components/Docs/DocsTitle.astro"

import { getCollection } from "astro:content"
const posts = await getCollection("blog")
const sortedPosts = posts.sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
)
const pageUrl = "https://bonjourr.fr/blog"
---

<Layout
	lang="en"
	id="blog"
	title="Bonjourr Blog · Updates and news"
	ogtitle="Bonjourr Blog · Updates and news"
	desc="Read the latest Bonjourr updates, release notes, and development news."
	canonical={pageUrl}
	ogImage="https://bonjourr.fr/twitter.jpg"
>
	<main>
		<DocsTitle
			title="Blog"
			thumbnail="/documentation/backgrounds/anna-scarfiello-5mH72l9_Xdg-unsplash.jpg"
		/>

		<section class="page-section">
			<div class="section-wrapper">
				<div class="post-grid">
					{
						sortedPosts.map((post) => (
							<article class="post-card">
								<a href={`/blog/${post.slug}`} class="post-title">
									{post.data.title}
								</a>
								<p class="post-meta">
									{new Date(post.data.pubDate).toLocaleDateString("en-US", {
										year: "numeric",
										month: "long",
										day: "numeric",
									})}
								</p>
								{post.data.image ? (
									<img
										src={post.data.image}
										alt={post.data.imageAlt ?? post.data.title}
										class="post-thumb"
									/>
								) : null}
								<p>{post.data.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</main>

	<style is:global>
		h1 {
			font-size: 3em;
			line-height: 2em;
			text-align: center;
		}

		.content {
			max-width: 1200px;
		}
	</style>

	<style></style>
</Layout>
