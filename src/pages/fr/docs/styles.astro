---
import Docs from "@layouts/Docs.astro"
import Link from "@components/Link.astro"
import { Code } from "astro-expressive-code/components"

import rolex from "@assets/documentation/snippets/rolex.txt?raw"
import noGpu from "@assets/documentation/snippets/no-gpu.txt?raw"
import potato from "@assets/documentation/snippets/potato.txt?raw"
import noCredits from "@assets/documentation/snippets/no-credits.txt?raw"
import clockWidth from "@assets/documentation/snippets/clock-width.txt?raw"
import colors from "@assets/documentation/snippets/colors.txt?raw"
import transparentBackground from "@assets/documentation/snippets/transparent-background.txt?raw"
import portraitBackground from "@assets/documentation/snippets/portrait-background.txt?raw"
import centerSearchbar from "@assets/documentation/snippets/center-searchbar.txt?raw"
import searchbarLogo from "@assets/documentation/snippets/searchbar-logo.txt?raw"
import MostVisitedLimit from "@assets/documentation/snippets/most-visited-limit.txt?raw"
import weatherIcons from "@assets/documentation/snippets/weather-icons.txt?raw"
import settingsIcon from "@assets/documentation/snippets/settings-icon.txt?raw"
---

<Docs
	title="Extraits de style"
	thumbnail="/documentation/backgrounds/braden-collum-CBcS51cGoSw.jpg"
	lang="fr"
>
	<p>
		Bonjourr est personnalisable via son interface de paramètres, mais il y a encore plein de
		choses que vous pouvez faire ! Copiez-collez ces extraits de style dans la section dédiée
		des paramètres pour débloquer de nouvelles possibilités.

		<br />
		<br />

		Vous voulez voir votre propre extrait de style ici ?
		<Link href="/#contact">Contactez-nous !</Link>
	</p>

	<section>
		<h2 id="backgrounds">Arrière-plans</h2>

		<h3 id="portrait-background">Arrière-plan portrait</h3>
		<Code lang="css" code={portraitBackground} />

		<h3 id="transparent-background">Arrière-plans transparents (Zen Browser)</h3>
		<Code lang="css" code={transparentBackground} />
	</section>

	<section>
		<h2 id="colors-and-icons">Couleurs et icônes</h2>

		<h3 id="custom-colors">Ajouter ou changer quelques couleurs</h3>
		<Code lang="css" code={colors} />

		<h3 id="custom-weather-icons">Icônes météo personnalisées</h3>
		<Code lang="css" code={weatherIcons} />

		<table>
			<thead>
				<tr>
					<th>Icône</th>
					<th>Condition</th>
					<th>ID Jour</th>
					<th>ID Nuit</th>
				</tr>
			</thead>
			<tbody>
				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-brokenclouds"
							></use>
						</svg>
					</td>
					<td>Nuages fragmentés</td>
					<td>weather-day-brokenclouds</td>
					<td>weather-night-brokenclouds</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-clearsky"
							></use>
						</svg>
					</td>
					<td>Ciel dégagé</td>
					<td>weather-day-clearsky</td>
					<td>weather-night-clearsky</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-fewclouds"
							></use>
						</svg>
					</td>
					<td>Peu de nuages</td>
					<td>weather-day-fewclouds</td>
					<td>weather-night-fewclouds</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-lightrain"
							></use>
						</svg>
					</td>
					<td>Pluie légère</td>
					<td>weather-day-lightrain</td>
					<td>weather-night-lightrain</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-mist"></use>
						</svg>
					</td>
					<td>Brume</td>
					<td>weather-day-mist</td>
					<td>weather-night-mist</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use
								href="/documentation/weather-sprites.svg#weather-day-overcastclouds"
							></use>
						</svg>
					</td>
					<td>Nuages couverts</td>
					<td>weather-day-overcastclouds</td>
					<td>weather-night-overcastclouds</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-rain"></use>
						</svg>
					</td>
					<td>Pluie</td>
					<td>weather-day-rain</td>
					<td>weather-night-rain</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-snow"></use>
						</svg>
					</td>
					<td>Neige</td>
					<td>weather-day-snow</td>
					<td>weather-night-snow</td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-sunnyrain"
							></use>
						</svg>
					</td>
					<td>Pluie ensoleillée</td>
					<td>weather-day-sunnyrain</td>
					<td></td>
				</tr>

				<tr>
					<td>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
							<use href="/documentation/weather-sprites.svg#weather-day-thunderstorm"
							></use>
						</svg>
					</td>
					<td>Orage</td>
					<td>weather-day-thunderstorm</td>
					<td>weather-night-thunderstorm</td>
				</tr>
			</tbody>
		</table>

		<h3 id="custom-settings-icon">Icône de paramètres personnalisée</h3>
		<Code lang="css" code={settingsIcon} />
	</section>

	<section>
		<h2 id="colors">Couleurs</h2>

		<h3 id="colors">Ajouter ou changer quelques couleurs</h3>
		<Code lang="css" code={colors} />
	</section>

	<section>
		<h2 id="quick-links">Liens rapides</h2>

		<h3 id="clock-width">Limiter mes sites les plus visités</h3>
		<Code lang="css" code={MostVisitedLimit} />
	</section>

	<section>
		<h2 id="clock">Horloge</h2>

		<h3 id="clock-width">J’aime les horloges bien larges</h3>
		<Code lang="css" code={clockWidth} />

		<h3 id="rolex">Rolex 😎</h3>
		<Code lang="css" code={rolex} />
	</section>

	<section>
		<h2 id="fonts">Barre de recherche</h2>

		<h3 id="center-searchbar">Centrer le placeholder de la barre de recherche</h3>
		<Code lang="css" code={centerSearchbar} />

		<h3 id="searchbar-logo">Ajouter un logo à gauche de la barre de recherche</h3>
		<Code lang="css" code={searchbarLogo} />
		<i>Proposé par <a href="https://bsky.app/profile/visn.es">Kim Visnes</a></i>
	</section>

	<section>
		<h2 id="other">Autres</h2>

		<h3 id="no-credits">Je me fiche des crédits aux artistes</h3>
		<Code lang="css" code={noCredits} />

		<h3 id="no-gpu-computer">Pas de GPU, que du CPU 😠</h3>
		<Code lang="css" code={noGpu} />

		<h3 id="potato-computer">Pour les ordinateurs lents</h3>
		<Code lang="css" code={potato} />
	</section>
</Docs>
